@model Product
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" style="width: 100%;" />
        </div>
        <div class="col-md-6">
            <h1>@Model.Name</h1>
            <p class="lead text-muted">@Model.Description</p>
            <h3 class="text-primary">Price: ₹@Model.PricePerDay <small class="text-muted">/ day</small></h3>
            <hr />
            
            <div class="mt-4 d-flex gap-2">
                <a asp-action="Confirm" asp-controller="Rent" asp-route-id="@Model.Id"
                       class="btn btn-success btn-lg @(Model.IsAvailable ? "" : "disabled")">
                    Rent This Now
                </a>
                
                <a asp-action="Index" class="btn btn-secondary btn-lg">Back to List</a>

                @if (!string.IsNullOrEmpty(HttpContextAccessor.HttpContext.Session.GetString("UserEmail")))
                {
                    <form asp-action="Delete" asp-controller="Product" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to remove this item?');">
                        <button type="submit" class="btn btn-danger btn-lg">Remove Item</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>