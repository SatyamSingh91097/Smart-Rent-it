@model Product
@{
    ViewData["Title"] = "List Your Item";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 shadow p-4 rounded bg-body-tertiary border">
        <h2 class="mb-4 text-body border-bottom pb-2">List Your Item for Rent</h2>
        
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label text-body">Item Name</label>
                <input asp-for="Name" class="form-control bg-body text-body" required />
            </div>
            
            <div class="mb-3">
                <label asp-for="Description" class="form-label text-body">Description</label>
                <textarea asp-for="Description" class="form-control bg-body text-body" rows="3" required></textarea>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PricePerDay" class="form-label text-body">Price (₹/day)</label>
                    <input asp-for="PricePerDay" type="number" class="form-control bg-body text-body" required />
                </div>
                
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsAvailable" class="form-check-input" checked />
                        <label class="form-check-label text-body">Available Now?</label>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-success px-5 shadow-sm">Publish Item</button>
            </div>
        </form>
    </div>
</div>