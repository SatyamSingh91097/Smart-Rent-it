@model Product
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = Model.Name;
}

<style>
    .details-container {
        padding: 50px 0;
    }

    /* Left Side: Image Presentation */
    .product-img-wrapper {
        position: sticky;
        top: 100px;
        overflow: hidden;
        border-radius: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        background: #f8fafc;
        transition: transform 0.3s ease;
    }

    .product-img-wrapper:hover {
        transform: scale(1.02);
    }

    .main-product-img {
        width: 100%;
        height: auto;
        display: block;
        transition: filter 0.3s ease;
    }

    /* Right Side: Content Info */
    .product-info-card {
        padding-left: 40px;
    }

    .badge-status {
        font-size: 0.8rem;
        font-weight: 700;
        padding: 8px 16px;
        border-radius: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 20px;
    }

    .product-title {
        font-weight: 800;
        font-size: 2.8rem;
        letter-spacing: -1px;
        color: #1e293b;
        line-height: 1.2;
    }

    [data-bs-theme="dark"] .product-title {
        color: #f1f5f9;
    }

    .price-box {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        padding: 25px;
        border-radius: 20px;
        border-left: 5px solid #667eea;
        margin: 30px 0;
    }

    .price-value {
        font-size: 2.2rem;
        font-weight: 800;
        color: #667eea;
        display: block;
    }

    .action-buttons .btn {
        padding: 15px 30px;
        border-radius: 16px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .btn-rent {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
    }

    .btn-rent:hover:not(.disabled) {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-rent.disabled {
        background: #94a3b8;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .specs-list {
        list-style: none;
        padding: 0;
        margin-top: 30px;
    }

    .specs-list li {
        padding: 12px 0;
        border-bottom: 1px solid #edf2f7;
        color: #64748b;
        display: flex;
        align-items: center;
    }

    [data-bs-theme="dark"] .specs-list li {
        border-color: #334155;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .product-info-card { padding-left: 15px; margin-top: 30px; }
        .product-title { font-size: 2rem; }
    }
</style>

<div class="container details-container">
    <div class="row">
        <div class="col-lg-6">
            <div class="product-img-wrapper">
                <img src="@Model.ImageUrl" class="main-product-img" alt="@Model.Name" />
            </div>
        </div>

        <div class="col-lg-6">
            <div class="product-info-card">
                @if (Model.IsAvailable)
                {
                    <span class="badge-status bg-success-subtle text-success">● Available for Rent</span>
                }
                else
                {
                    <span class="badge-status bg-danger-subtle text-danger">● Currently Rented</span>
                }

                <h1 class="product-title">@Model.Name</h1>
                <p class="lead text-muted mt-3">@Model.Description</p>

                <div class="price-box">
                    <span class="text-muted small fw-bold text-uppercase">Rental Price</span>
                    <span class="price-value">₹@Model.PricePerDay <small style="font-size: 1rem; font-weight: 500;">/ day</small></span>
                </div>

                <ul class="specs-list">
                    <li><span class="me-2">✅</span> Verified Rental Item</li>
                    <li><span class="me-2">🛡️</span> Smart Rent-it Protection Included</li>
                    <li><span class="me-2">🚚</span> Local Pick-up Available</li>
                </ul>

                <hr class="my-4" />

                <div class="action-buttons d-flex flex-wrap gap-3">
                    <a asp-action="Confirm" asp-controller="Rent" asp-route-id="@Model.Id"
                       class="btn btn-rent flex-grow-1 @(Model.IsAvailable ? "" : "disabled")">
                        @(Model.IsAvailable ? "Rent This Item Now" : "Currently Unavailable")
                    </a>
                    
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to Browsing
                    </a>

                    @if (!string.IsNullOrEmpty(HttpContextAccessor.HttpContext.Session.GetString("UserEmail")))
                    {
                        <form asp-action="Delete" asp-controller="Product" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Wait! Are you sure you want to permanently delete this listing?');">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete Listing
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>