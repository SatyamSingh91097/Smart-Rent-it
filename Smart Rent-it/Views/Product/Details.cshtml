@model Product

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" style="width: 100%;" />
        </div>
        <div class="col-md-6">
            <h1>@Model.Name</h1>
            <p class="lead text-muted">@Model.Description</p>
            <h3 class="text-primary">Price: ₹@Model.PricePerDay <small class="text-muted">/ day</small></h3>
            <hr />
            
            <div class="mt-4">
                <button class="btn btn-success btn-lg @(Model.IsAvailable ? "" : "disabled")">
                    Rent This Now
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Back to List</a>
            </div>
        </div>
    </div>
</div>