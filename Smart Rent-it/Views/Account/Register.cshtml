@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4 shadow p-4 rounded bg-body-tertiary border">
        <h3 class="text-center mb-4 text-body">Create Account</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label text-body">Full Name</label>
                <input asp-for="FullName" class="form-control bg-body text-body" placeholder="Enter your name" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-body">Email Address</label>
                <input asp-for="Email" class="form-control bg-body text-body" placeholder="email@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-body">Password</label>
                <input asp-for="Password" type="password" class="form-control bg-body text-body" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-body">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control bg-body text-body" required />
            </div>
            <button type="submit" class="btn btn-success w-100 shadow-sm">Register Now</button>
        </form>

        <div class="mt-3 text-center">
            <p class="text-body-secondary">
                Already have an account?
                <a asp-action="Login" asp-controller="Account" class="text-primary text-decoration-none fw-bold">Login</a>
            </p>
        </div>
    </div>
</div>