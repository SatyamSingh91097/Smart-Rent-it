@model IEnumerable<Product>
@{
    ViewData["Title"] = "Browse Items";
}

<style>
    .browse-container {
        padding: 40px 0;
    }

    .section-title {
        font-weight: 800;
        letter-spacing: -1px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 40px;
    }

    /* Product Card Styling */
    .product-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    [data-bs-theme="dark"] .product-card {
        background: #1e293b;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.15);
    }

    /* Image Container for Uniformity */
    .img-container {
        height: 220px;
        overflow: hidden;
        position: relative;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.1);
    }

    /* Status Badge Over Image */
    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 6px 12px;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        backdrop-filter: blur(4px);
    }

    .card-body {
        padding: 20px;
    }

    .card-title {
        font-weight: 700;
        font-size: 1.15rem;
        color: #1e293b;
        margin-bottom: 8px;
    }

    [data-bs-theme="dark"] .card-title {
        color: #f1f5f9;
    }

    .price-tag {
        font-size: 1.25rem;
        font-weight: 800;
        color: #667eea;
    }

    .btn-details {
        border: 2px solid #667eea;
        color: #667eea;
        border-radius: 12px;
        font-weight: 700;
        padding: 10px;
        transition: all 0.3s ease;
    }

    .btn-details:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
        color: white;
    }

    /* Animation */
    .fade-in {
        animation: fadeIn 0.8s ease-in;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

<div class="container browse-container">
    <h2 class="text-center section-title fade-in">Available Items for Rent</h2>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4 fade-in">
                <div class="card product-card h-100">
                    <div class="img-container">
                        <img src="@item.ImageUrl" class="product-img" alt="@item.Name">
                        
                        @if (item.IsAvailable)
                        {
                            <span class="status-badge bg-success text-white">Available</span>
                        }
                        else
                        {
                            <span class="status-badge bg-danger text-white">Rented Out</span>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="text-muted small mb-3 text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 40px;">
                            @item.Description
                        </p>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center mb-3">
                            <span class="price-tag">₹@item.PricePerDay<small class="text-muted" style="font-size: 0.8rem; font-weight: 400;"> / day</small></span>
                        </div>

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-details w-100">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>